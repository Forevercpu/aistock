{
  "name": "aistock",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "dev:admin": "pnpm --filter aistock-admin-fe dev",
    "dev:user": "pnpm --filter aistock-user-fe dev",
    "dev:be": "pnpm --filter aistock-be start:dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "db:generate": "pnpm --filter aistock-be db:generate",
    "db:migrate": "pnpm --filter aistock-be db:migrate",
    "db:deploy": "pnpm --filter aistock-be db:deploy"
  }
}
