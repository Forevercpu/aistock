generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "mysql"
}

enum PublishStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

enum SyncStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
}

model AdminUser {
  id           Int      @id @default(autoincrement())
  username     String   @unique @db.VarChar(50)
  passwordHash String   @map("password_hash") @db.VarChar(255)
  displayName  String   @map("display_name") @db.VarChar(50)
  role         String   @default("admin") @db.VarChar(30)
  enabled      Boolean  @default(true)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  @@map("admin_users")
}

model Company {
  id             Int            @id @default(autoincrement())
  stockCode      String         @unique @map("stock_code") @db.VarChar(10)
  name           String         @db.VarChar(100)
  shortName      String?        @map("short_name") @db.VarChar(50)
  exchange       String         @db.VarChar(20)
  description    String?        @db.Text
  logoUrl        String?        @map("logo_url") @db.VarChar(500)
  status         PublishStatus  @default(DRAFT)
  foundedAt      DateTime?      @map("founded_at") @db.Date
  listedAt       DateTime?      @map("listed_at") @db.Date
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")
  sectors        CompanySector[]
  tags           CompanyTag[]
  products       Product[]
  announcements Announcement[]
  @@index([name])
  @@map("companies")
}

model Sector {
  id        Int             @id @default(autoincrement())
  name      String          @unique @db.VarChar(80)
  type      String          @default("industry") @db.VarChar(30)
  parentId  Int?            @map("parent_id")
  createdAt DateTime        @default(now()) @map("created_at")
  companies CompanySector[]
  @@map("sectors")
}

model CompanySector {
  companyId Int     @map("company_id")
  sectorId  Int     @map("sector_id")
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  sector    Sector  @relation(fields: [sectorId], references: [id], onDelete: Cascade)
  @@id([companyId, sectorId])
  @@map("company_sectors")
}

model Tag {
  id        Int          @id @default(autoincrement())
  name      String       @unique @db.VarChar(50)
  color     String?      @db.VarChar(20)
  companies CompanyTag[]
  @@map("tags")
}

model CompanyTag {
  companyId Int     @map("company_id")
  tagId     Int     @map("tag_id")
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)
  @@id([companyId, tagId])
  @@map("company_tags")
}

model Product {
  id          Int      @id @default(autoincrement())
  companyId   Int      @map("company_id")
  name        String   @db.VarChar(100)
  description String?  @db.Text
  revenueRate Decimal? @map("revenue_rate") @db.Decimal(8, 4)
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now()) @map("created_at")
  @@index([companyId])
  @@map("products")
}

model Announcement {
  id             Int          @id @default(autoincrement())
  companyId      Int          @map("company_id")
  title          String       @db.VarChar(255)
  sourceUrl      String?      @map("source_url") @db.VarChar(1000)
  publishedAt    DateTime     @map("published_at")
  aiSummary      String?      @map("ai_summary") @db.Text
  reviewStatus   ReviewStatus @default(PENDING) @map("review_status")
  company        Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now()) @map("created_at")
  @@index([companyId, publishedAt])
  @@map("announcements")
}

model IndustryChain {
  id          Int      @id @default(autoincrement())
  name        String   @unique @db.VarChar(100)
  description String?  @db.Text
  graphData   Json?    @map("graph_data")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  @@map("industry_chains")
}

model QuizQuestion {
  id            Int           @id @default(autoincrement())
  type          String        @db.VarChar(30)
  question      String        @db.Text
  options       Json?
  answer        String        @db.Text
  explanation   String?       @db.Text
  status        PublishStatus @default(DRAFT)
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")
  @@map("quiz_questions")
}

model SyncTask {
  id          Int        @id @default(autoincrement())
  name        String     @db.VarChar(100)
  type        String     @db.VarChar(50)
  status      SyncStatus @default(PENDING)
  lastRunAt   DateTime?  @map("last_run_at")
  errorMessage String?   @map("error_message") @db.Text
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")
  @@map("sync_tasks")
}
