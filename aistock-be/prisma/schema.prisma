generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "mysql"
}

/// 后台内容统一发布状态。
enum PublishStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

/// AI 解析结果的人工审核状态。
enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

/// 数据解析或同步任务的执行状态。
enum SyncStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
}

/// 管理后台登录账号。
model AdminUser {
  id           Int      @id @default(autoincrement())
  username     String   @unique @db.VarChar(50)
  passwordHash String   @map("password_hash") @db.VarChar(255)
  displayName  String   @map("display_name") @db.VarChar(50)
  role         String   @default("admin") @db.VarChar(30)
  enabled      Boolean  @default(true)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  reviewedAiResults AiParseResult[]
  auditLogs     AuditLog[]
  @@map("admin_users")
}

/// 上市公司知识库主体。
model Company {
  id             Int            @id @default(autoincrement())
  stockCode      String         @unique @map("stock_code") @db.VarChar(10)
  name           String         @db.VarChar(100)
  shortName      String?        @map("short_name") @db.VarChar(50)
  exchange       String         @db.VarChar(20)
  description    String?        @db.Text
  logoUrl        String?        @map("logo_url") @db.VarChar(500)
  status         PublishStatus  @default(DRAFT)
  foundedAt      DateTime?      @map("founded_at") @db.Date
  listedAt       DateTime?      @map("listed_at") @db.Date
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")
  sectors        CompanySector[]
  tags           CompanyTag[]
  products       Product[]
  announcements Announcement[]
  chainNodes    IndustryChainNodeCompany[]
  quizQuestions QuizQuestion[]
  @@index([name])
  @@map("companies")
}

/// 可分层的行业板块、概念、地域或指数分类。
model Sector {
  id        Int             @id @default(autoincrement())
  name      String          @unique @db.VarChar(80)
  type      String          @default("industry") @db.VarChar(30)
  parentId  Int?            @map("parent_id")
  createdAt DateTime        @default(now()) @map("created_at")
  updatedAt DateTime        @updatedAt @map("updated_at")
  parent    Sector?          @relation("SectorTree", fields: [parentId], references: [id], onDelete: SetNull)
  children  Sector[]         @relation("SectorTree")
  companies CompanySector[]
  @@index([parentId])
  @@map("sectors")
}

/// 公司与板块的多对多关系。
model CompanySector {
  companyId Int     @map("company_id")
  sectorId  Int     @map("sector_id")
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  sector    Sector  @relation(fields: [sectorId], references: [id], onDelete: Cascade)
  @@id([companyId, sectorId])
  @@map("company_sectors")
}

/// 可复用的公司知识标签。
model Tag {
  id        Int          @id @default(autoincrement())
  name      String       @unique @db.VarChar(50)
  color     String?      @db.VarChar(20)
  companies CompanyTag[]
  @@map("tags")
}

/// 公司与标签的多对多关系。
model CompanyTag {
  companyId Int     @map("company_id")
  tagId     Int     @map("tag_id")
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)
  @@id([companyId, tagId])
  @@map("company_tags")
}

/// 公司主营产品及其营收占比。
model Product {
  id          Int      @id @default(autoincrement())
  companyId   Int      @map("company_id")
  name        String   @db.VarChar(100)
  description String?  @db.Text
  revenueRate Decimal? @map("revenue_rate") @db.Decimal(8, 4)
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now()) @map("created_at")
  @@index([companyId])
  @@map("products")
}

/// 上市公司公告原文与处理状态。
model Announcement {
  id             Int          @id @default(autoincrement())
  companyId      Int          @map("company_id")
  title          String       @db.VarChar(255)
  sourceUrl      String?      @map("source_url") @db.VarChar(1000)
  sourceName     String?      @map("source_name") @db.VarChar(100)
  category       String?      @db.VarChar(50)
  content        String?      @db.LongText
  publishedAt    DateTime     @map("published_at")
  aiSummary      String?      @map("ai_summary") @db.Text
  parseStatus    SyncStatus   @default(PENDING) @map("parse_status")
  reviewStatus   ReviewStatus @default(PENDING) @map("review_status")
  lastParsedAt   DateTime?    @map("last_parsed_at")
  company        Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  aiResults      AiParseResult[]
  createdAt      DateTime     @default(now()) @map("created_at")
  @@index([companyId, publishedAt])
  @@map("announcements")
}

/// 产业链基础信息和图谱汇总。
model IndustryChain {
  id          Int      @id @default(autoincrement())
  name        String   @unique @db.VarChar(100)
  description String?  @db.Text
  graphData   Json?    @map("graph_data")
  status      PublishStatus @default(DRAFT)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  nodes       IndustryChainNode[]
  edges       IndustryChainEdge[]
  quizQuestions QuizQuestion[]
  @@map("industry_chains")
}

/// 产业链画布中的业务节点。
model IndustryChainNode {
  id          Int      @id @default(autoincrement())
  chainId     Int      @map("chain_id")
  name        String   @db.VarChar(100)
  type        String   @default("stage") @db.VarChar(30)
  stage       String   @default("midstream") @db.VarChar(30)
  description String?  @db.Text
  positionX   Float    @default(0) @map("position_x")
  positionY   Float    @default(0) @map("position_y")
  chain       IndustryChain @relation(fields: [chainId], references: [id], onDelete: Cascade)
  sourceEdges IndustryChainEdge[] @relation("SourceNode")
  targetEdges IndustryChainEdge[] @relation("TargetNode")
  companies   IndustryChainNodeCompany[]
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  @@index([chainId])
  @@map("industry_chain_nodes")
}

/// 产业链节点之间的有向关系。
model IndustryChainEdge {
  id           Int      @id @default(autoincrement())
  chainId      Int      @map("chain_id")
  sourceNodeId Int      @map("source_node_id")
  targetNodeId Int      @map("target_node_id")
  label        String?  @db.VarChar(100)
  chain        IndustryChain @relation(fields: [chainId], references: [id], onDelete: Cascade)
  sourceNode   IndustryChainNode @relation("SourceNode", fields: [sourceNodeId], references: [id], onDelete: Cascade)
  targetNode   IndustryChainNode @relation("TargetNode", fields: [targetNodeId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now()) @map("created_at")
  @@index([chainId])
  @@index([sourceNodeId])
  @@index([targetNodeId])
  @@map("industry_chain_edges")
}

/// 图谱节点与上市公司的多对多关系。
model IndustryChainNodeCompany {
  nodeId    Int @map("node_id")
  companyId Int @map("company_id")
  node      IndustryChainNode @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  @@id([nodeId, companyId])
  @@map("industry_chain_node_companies")
}

/// 公告的 AI 原始解析、人工修订和审核记录。
model AiParseResult {
  id             Int          @id @default(autoincrement())
  announcementId Int          @map("announcement_id")
  rawResult      Json         @map("raw_result")
  editedResult   Json?        @map("edited_result")
  modelName      String       @default("mock-provider") @map("model_name") @db.VarChar(80)
  status         ReviewStatus @default(PENDING)
  reviewerId     Int?         @map("reviewer_id")
  reviewedAt     DateTime?    @map("reviewed_at")
  failureReason  String?      @map("failure_reason") @db.Text
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  reviewer       AdminUser?   @relation(fields: [reviewerId], references: [id], onDelete: SetNull)
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  @@index([announcementId])
  @@index([status])
  @@map("ai_parse_results")
}

/// 用户端知识挑战题目。
model QuizQuestion {
  id            Int           @id @default(autoincrement())
  type          String        @db.VarChar(30)
  question      String        @db.Text
  options       Json?
  answer        String        @db.Text
  explanation   String?       @db.Text
  difficulty    String        @default("medium") @db.VarChar(20)
  score         Int           @default(10)
  weight        Int           @default(0)
  companyId     Int?          @map("company_id")
  chainId       Int?          @map("chain_id")
  status        PublishStatus @default(DRAFT)
  company       Company?      @relation(fields: [companyId], references: [id], onDelete: SetNull)
  chain         IndustryChain? @relation(fields: [chainId], references: [id], onDelete: SetNull)
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")
  @@index([companyId])
  @@index([chainId])
  @@map("quiz_questions")
}

/// 外部数据同步或批处理任务。
model SyncTask {
  id          Int        @id @default(autoincrement())
  name        String     @db.VarChar(100)
  type        String     @db.VarChar(50)
  status      SyncStatus @default(PENDING)
  lastRunAt   DateTime?  @map("last_run_at")
  errorMessage String?   @map("error_message") @db.Text
  lastResult  Json?      @map("last_result")
  runCount    Int        @default(0) @map("run_count")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")
  @@map("sync_tasks")
}

/// 管理员关键数据变更的审计记录。
model AuditLog {
  id         Int       @id @default(autoincrement())
  adminId    Int?      @map("admin_id")
  module     String    @db.VarChar(50)
  action     String    @db.VarChar(50)
  targetType String?   @map("target_type") @db.VarChar(50)
  targetId   String?   @map("target_id") @db.VarChar(50)
  summary    String    @db.VarChar(500)
  metadata   Json?
  admin      AdminUser? @relation(fields: [adminId], references: [id], onDelete: SetNull)
  createdAt  DateTime  @default(now()) @map("created_at")
  @@index([adminId])
  @@index([module, createdAt])
  @@map("audit_logs")
}
